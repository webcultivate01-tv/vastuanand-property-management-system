# ─────────────────────────────────────────────
# VASTUANAND REAL ESTATE — ENVIRONMENT CONFIG
# ─────────────────────────────────────────────

APP_NAME="Vastu Anand Real Estate"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://vastuanandm.com
APP_TIMEZONE=Asia/Kolkata
APP_KEY=base64:CHANGE_ME_TO_RANDOM_32_BYTES

# MongoDB Atlas
MONGO_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority"
MONGO_DB=vastuanand

# JWT
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_ALGO=HS256
JWT_TTL=86400          # 24 hours
JWT_REFRESH_TTL=604800 # 7 days

# Mail (SMTP)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=info@vastuanandm.com
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@vastuanandm.com
MAIL_FROM_NAME="Vastu Anand Real Estate"

# WhatsApp / SMS (optional)
WHATSAPP_NUMBER=+919876543210
WHATSAPP_API_TOKEN=

# Google Maps
GOOGLE_MAPS_KEY=

# Recaptcha
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# Storage
UPLOAD_MAX_SIZE=8388608  # 8 MB

# Admin Bootstrap (first run only)
ADMIN_EMAIL=admin@vastuanandm.com
ADMIN_PASSWORD=ChangeMeNow#2025

{
    "name": "vastuanand/real-estate",
    "description": "Vastu Anand — Premium Real Estate Platform (Mumbai). MVC PHP 8 + MongoDB Atlas + JWT.",
    "type": "project",
    "license": "Proprietary",
    "require": {
        "php": ">=8.0",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9",
        "ramsey/uuid": "^4.7",
        "mongodb/mongodb": "^1.17"
    },
    "suggest": {
        "ext-mongodb": "Required at runtime to connect to MongoDB Atlas. Enable in hPanel → PHP Configuration."
    },
    "autoload": {
        "classmap": [
            "app/"
        ],
        "files": [
            "app/helpers/functions.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.0.0",
            "ext-mongodb": "1.18.0"
        },
        "audit": {
            "abandoned": "ignore"
        }
    },
    "scripts": {
        "seed": "php database/seed.php",
        "serve": "php -S localhost:8000 -t public"
    }
}
